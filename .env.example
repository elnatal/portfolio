# Turso database (get from: turso db show <db-name> and turso db tokens create <db-name>)
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN=""

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# Admin credentials
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# AI Chatbot (Groq — free tier, get key at https://console.groq.com/keys)
GROQ_API_KEY=